<Window x:Class="WCMissionViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WCMissionViewer"
        Title="WC Mission Viewer" Height="750" Width="1100"
        MinHeight="550" MinWidth="850"
        Background="#FF1A1A2E" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Dark theme styles -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF00CCFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">
        <!-- Top bar: File + System/Mission selectors -->
        <Border DockPanel.Dock="Top" Background="#FF16213E" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="📂 Open MODULE..." Click="OpenFile_Click"
                        Padding="8,4" Margin="0,0,16,0" Background="#FF0F3460" Foreground="White"
                        BorderBrush="#FF00CCFF" Cursor="Hand"/>

                <TextBlock Grid.Column="1" Text="System:" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="2" x:Name="SystemSelector" Width="160" 
                          SelectionChanged="SystemSelector_Changed" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="3" Text="Mission:" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="4" x:Name="MissionSelector" Width="80" 
                          SelectionChanged="MissionSelector_Changed" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="5" x:Name="SortieLabel" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Text=""/>

                <TextBlock Grid.Column="7" x:Name="FileLabel" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Text="No file loaded" HorizontalAlignment="Right"/>
                <Button Grid.Column="8" Content="?" Click="About_Click"
                        Width="26" Height="26" Margin="8,0,0,0" 
                        Background="#FF0F3460" Foreground="#FF00CCFF"
                        BorderBrush="#FF00CCFF" FontWeight="Bold" FontSize="14" Cursor="Hand"
                        ToolTip="About WC Mission Tools"/>
            </Grid>
        </Border>

        <!-- Main content: Left (map + briefing), Right (ships + nav detail) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Nav Map + Briefing -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- Nav Map Canvas -->
                <Border Grid.Row="0" Background="#FF0A0A1A" CornerRadius="4" BorderBrush="#FF333366" BorderThickness="1">
                    <Grid>
                        <Canvas x:Name="NavMapCanvas" ClipToBounds="True"
                                MouseLeftButtonDown="NavMap_Click"/>
                        <TextBlock Text="NAV MAP" Style="{StaticResource HeaderText}" 
                                   Margin="8,4,0,0" IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Briefing Text -->
                <TextBlock Grid.Row="1" Text="BRIEFING" Style="{StaticResource HeaderText}" Margin="0,8,0,0"/>
                <Border Grid.Row="2" Background="#FF16213E" CornerRadius="4" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BriefingPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Right panel: Ship List + Nav/Ship Detail -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- Ship List -->
                <Border Grid.Row="0" Background="#FF16213E" CornerRadius="4">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SHIPS" Style="{StaticResource HeaderText}" Margin="8,4,0,0"/>
                        <ListBox x:Name="ShipList" Background="Transparent" BorderThickness="0"
                                 SelectionChanged="ShipList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding IndexLabel}" 
                                                   Foreground="#FF888888" FontFamily="Consolas" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ClassName}" 
                                                   Foreground="{Binding FactionColor}" FontWeight="SemiBold" FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PilotName}" 
                                                   Foreground="#FFCCCCCC" FontSize="11"/>
                                        <TextBlock Grid.Column="3" Text="{Binding OrdersName}" 
                                                   Foreground="#FF888888" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Detail Panel Header -->
                <TextBlock Grid.Row="1" x:Name="DetailHeader" Text="DETAILS" 
                           Style="{StaticResource HeaderText}" Margin="0,8,0,0"/>

                <!-- Detail Panel -->
                <Border Grid.Row="2" Background="#FF16213E" CornerRadius="4" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DetailPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
